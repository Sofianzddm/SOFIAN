// ============================================
// GLOW UP AGENCE - SCHÉMA PRISMA V9
// V8 + Tracking Talentbook
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  HEAD_OF
  HEAD_OF_INFLUENCE
  HEAD_OF_SALES
  TM
  CM
  TALENT
  JURISTE
  STRATEGY_PLANNER
  CASTING_MANAGER
}

enum Departement {
  INFLUENCE
  SALES
  ADMIN
}

enum TypeContenu {
  STORY
  STORY_CONCOURS
  POST
  POST_CONCOURS
  POST_COMMUN
  POST_CROSSPOST
  REEL
  REEL_CROSSPOST
  REEL_CONCOURS
  TIKTOK_VIDEO
  TIKTOK_VIDEO_CONCOURS
  YOUTUBE_VIDEO
  YOUTUBE_SHORT
  SNAPCHAT_STORY
  SNAPCHAT_SPOTLIGHT
  EVENT
  SHOOTING
  AMBASSADEUR
}

enum Source {
  INBOUND
  OUTBOUND
}

enum StatutCollab {
  NEGO
  PERDU
  GAGNE
  EN_COURS
  PUBLIE
  FACTURE_RECUE
  PAYE
}

enum StatutNego {
  BROUILLON
  EN_ATTENTE
  EN_DISCUSSION
  VALIDEE
  REFUSEE
  ANNULEE
}

enum StatutProspection {
  NOUVEAU
  CONTACTE
  EN_DISCUSSION
  PROPOSITION
  GAGNE
  PERDU
  STAND_BY
}

// Statut des contacts dans les fichiers de prospection
enum StatutProspectionContact {
  EN_ATTENTE
  CONTACTE
  EN_NEGOC
  GAGNE
  PERDU
}

enum StatutAction {
  A_FAIRE
  EN_ATTENTE
  GAGNE
  PERDU
  ANNULE
}

enum StatutDocument {
  BROUILLON
  ENVOYE
  VALIDE
  REFUSE
  PAYE
  ANNULE
}

enum StatutGift {
  BROUILLON
  EN_ATTENTE
  EN_COURS
  ATTENTE_MARQUE
  ACCEPTE
  REFUSE
  ENVOYE
  RECU
  ANNULE
}

enum TypeDocument {
  DEVIS
  BON_DE_COMMANDE
  FACTURE
  AVOIR
}

enum TypeTVA {
  FRANCE
  EU_INTRACOM
  EU_SANS_TVA
  HORS_EU
}

// Statut des devis (quotes)
enum QuoteStatus {
  DRAFT
  REGISTERED
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  INVOICED
  CANCELLED
}

// Types d'événements sur documents (factures + devis)
enum DocumentEventType {
  CREATED
  REGISTERED
  SENT
  SIGNED
  VIEWED
  PAYMENT
  STATUS_CHANGE
  EDITED
  CONVERTED
  REMINDER_SENT
  COMMENT
}

enum StatutCycle {
  A_VENIR
  EN_COURS
  PUBLIE
  FACTURE
  PAYE
}

enum TypeNotification {
  NOUVEAU_TALENT
  NOUVELLE_MARQUE
  BILAN_RETARD
  COLLAB_PUBLIE
  FACTURE_RECUE
  FACTURE_VALIDEE
  FACTURE_RELANCE
  COLLAB_GAGNEE
  PAIEMENT_RECU
  MENTION
  REVOIR_TARIFS
  GENERAL
  CONTRAT_MARQUE_APPROUVE
  CONTRAT_MARQUE_MODIFICATIONS
  INBOUND_OPPORTUNITY
}

enum DinnerCampaignStatus {
  DRAFT
  IN_REVIEW
  FINALIZED
}

enum DinnerCandidateSource {
  PLANNER
  CLIENT
}

enum DinnerCandidateStatus {
  PROPOSED
  APPROVED
  CONTACTED
  CREATOR_APPROVED
  REJECTED
}

enum DinnerEventType {
  CREATED
  MOVED
  COMMENT_ADDED
  EDITED
}

enum ContactMissionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContactMissionStatus {
  READY_FOR_CASTING
  EMAIL_DRAFTED
  APPROVED_BY_SALES
  SENT
  RELANCED
  CANCELLED
}

enum ContactMissionStage {
  STRATEGY_DEFINED
  TO_DRAFT
  DRAFTED_FOR_VALIDATION
  TO_SEND
  SENT
  RESPONSE_RECEIVED
  IN_NEGOTIATION
  WON
  LOST
}

enum InboundCategory {
  COLLAB_PAID
  PRESS_KIT
  EVENT_INVITE
  OTHER
}

enum InboundPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InboundStatus {
  NEW
  IN_REVIEW
  CONVERTED
  ARCHIVED
}

// ============================================
// USERS
// ============================================

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  prenom        String
  nom           String
  role          Role
  departement   Departement?
  telephone     String?
  actif         Boolean      @default(true)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  talent        Talent?      @relation("UserTalent")
  talentsGeres  Talent[]     @relation("ManagerTalents")
  
  negociations      Negociation[]   @relation("TMNegociations")
  negosValidees     Negociation[]   @relation("ValidateurNegociations")
  negoCommentaires  NegoCommentaire[]
  
  prospections      Prospection[]
  documentsCreated  Document[]      @relation("DocumentCreateur")
  
  demandesGiftCreees    DemandeGift[]           @relation("TMDemandeGift")
  demandesGiftGerees    DemandeGift[]           @relation("AMDemandeGift")
  commentairesGift      CommentaireGift[]
  
  collabsGerees         Collaboration[]         @relation("AccountManagerCollabs")
  // Historique documents / devis
  quotesCreated         Quote[]
  documentEvents        DocumentEvent[]
  documentComments      DocumentComment[]
  collaborationComments CollaborationComment[]
  notifications         Notification[]
  objectifsRecus       Objectif[]     @relation("ObjectifsRecus")
  objectifsCrees       Objectif[]     @relation("ObjectifsCrees")

  fichiersProspection  FichierProspection[]
  dossiersProspection  DossierProspection[]

  prospectionCommentaires ProspectionCommentaire[]
  prospectionHistoriques  ProspectionHistorique[]

  delegationsEmises  DelegationTM[] @relation("DelegationsEmises")
  delegationsRecues  DelegationTM[] @relation("DelegationsRecues")

  delegationActivites DelegationActivite[]

  contratMarqueAnnotations     ContratMarqueAnnotation[]
  contratMarqueCommentairesAuteur ContratMarqueCommentaire[] @relation("ContratMarqueCommentaireAuteur")
  dinnerCampaignsCreated DinnerCampaign[] @relation("DinnerCampaignCreatedBy")
  dinnerCandidatesCreated DinnerCreatorCandidate[] @relation("DinnerCandidateCreatedBy")
  dinnerCandidatesUpdated DinnerCreatorCandidate[] @relation("DinnerCandidateUpdatedBy")
  dinnerEvents DinnerCandidateEvent[]
  dinnerComments DinnerCandidateComment[]
  contactMissionsCreated ContactMission[] @relation("ContactMissionCreatedBy")
  prospectingCampaignsCreated TalentProspectingCampaign[] @relation("TalentProspectingCampaignCreatedBy")
  inboundConverted InboundOpportunity[] @relation("InboundConvertedBy")
  inboundArchived  InboundOpportunity[] @relation("InboundArchivedBy")
  cannesPresences  CannesPresence[] @relation("UserCannesPresences")

  @@map("users")
}

// ============================================
// TALENTS
// ============================================

model Talent {
  id            String    @id @default(cuid())
  
  userId        String?   @unique
  user          User?     @relation("UserTalent", fields: [userId], references: [id])
  
  managerId     String
  manager       User      @relation("ManagerTalents", fields: [managerId], references: [id])
  
  // Infos personnelles
  prenom        String
  nom           String
  email         String
  telephone     String?
  dateNaissance DateTime?
  
  bio           String?   @db.Text
  presentation  String?   @db.Text
  presentationEn String?  @db.Text
  
  // Adresse complète
  adresse       String?
  codePostal    String?
  ville         String?
  pays          String?   @default("France")
  
  photo         String?
  
  // Réseaux sociaux
  instagram     String?
  tiktok        String?
  youtube       String?
  snapchat      String?
  
  niches        String[]
  selectedClients String[]
  
  // Commissions
  commissionInbound   Decimal  @default(20)
  commissionOutbound  Decimal  @default(30)
  
  // Infos facturation (pour le portail talent)
  siret             String?
  iban              String?
  bic               String?
  titulaireCompte   String?
  nomBanque         String?
  formeJuridique    String?   // Auto-entrepreneur, SASU, EURL, etc.
  raisonSociale     String?
  numeroTVA         String?

  // Contact d'urgence
  contactUrgenceNom  String?
  contactUrgenceTel  String?
  contactUrgenceLien String?

  telephoneSecondaire String?
  nationalite         String?
  notesInternes      String?   @db.Text

  dateArrivee   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isArchived    Boolean   @default(false)
  orderBook     Int       @default(0)   // Ordre d'affichage dans le talent book (plus petit = plus haut)
  moyenneVuesStory Int?   // Vues moyennes story (pour calculateur CPM)
  moyenneVuesSnap  Int?   // Vues moyennes Snap (pour calculateur CPM Snap Vidéo)

  stats         TalentStats?
  tarifs        TalentTarifs?
  collaborations Collaboration[]
  negociations  Negociation[]
  talentbookEvents TalentbookEvent[]
  demandesGift  DemandeGift[]
  presskitTalents PressKitTalent[]
  partnerTalents  PartnerTalent[]
  agencyProjects AgencyProjectTalent[]
  partnerTarifOverrides PartnerTarifOverride[]
  contactMissions ContactMission[]
  prospectingCampaigns TalentProspectingCampaign[]
  inboundOpportunities InboundOpportunity[]
  quotes        Quote[]
  prospectionContacts ProspectionContact[]

  delegations DelegationTM[]
  delegationActivites DelegationActivite[]
  participantsVilla ParticipantVilla[]
  dinnerCandidates DinnerCreatorCandidate[]
  cannesPresences CannesPresence[] @relation("TalentCannesPresences")
  
  @@map("talents")
}

// ============================================
// STATS TALENT
// ============================================

model TalentStats {
  id            String    @id @default(cuid())
  
  talentId      String    @unique
  talent        Talent    @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  igFollowers           Int?
  igFollowersEvol       Decimal?
  igEngagement          Decimal?
  igEngagementEvol      Decimal?
  igGenreFemme          Decimal?
  igGenreHomme          Decimal?
  igAge13_17            Decimal?
  igAge18_24            Decimal?
  igAge25_34            Decimal?
  igAge35_44            Decimal?
  igAge45Plus           Decimal?
  igLocFrance           Decimal?
  igLocAutre            String?
  
  ttFollowers           Int?
  ttFollowersEvol       Decimal?
  ttEngagement          Decimal?
  ttEngagementEvol      Decimal?
  ttGenreFemme          Decimal?
  ttGenreHomme          Decimal?
  ttAge13_17            Decimal?
  ttAge18_24            Decimal?
  ttAge25_34            Decimal?
  ttAge35_44            Decimal?
  ttAge45Plus           Decimal?
  ttLocFrance           Decimal?
  ttLocAutre            String?
  
  ytAbonnes             Int?
  ytAbonnesEvol         Decimal?

  // Stories / vues lien – saisis manuellement par le TM
  storyViews30d         Int?
  storyViews7d          Int?
  storyLinkClicks30d    Int?
  storyScreenshots      Json?
  
  lastUpdate    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("talent_stats")
}

// ============================================
// TARIFS TALENT
// ============================================

model TalentTarifs {
  id            String    @id @default(cuid())
  
  talentId      String    @unique
  talent        Talent    @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  tarifStory            Decimal?
  tarifStoryConcours    Decimal?
  tarifPost             Decimal?
  tarifPostConcours     Decimal?
  tarifPostCommun       Decimal?
  tarifPostCrosspost    Decimal?
  tarifReel             Decimal?
  tarifReelCrosspost    Decimal?
  tarifReelConcours     Decimal?
  tarifTiktokVideo      Decimal?
  tarifTiktokConcours   Decimal?
  tarifYoutubeVideo     Decimal?
  tarifYoutubeShort     Decimal?
  tarifSnapchatStory    Decimal?
  tarifSnapchatSpotlight Decimal?
  tarifEvent            Decimal?
  tarifShooting         Decimal?
  tarifAmbassadeur      Decimal?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("talent_tarifs")
}

// ============================================
// MARQUES
// ============================================

model Marque {
  id            String    @id @default(cuid())
  
  nom           String
  secteur       String?
  siteWeb       String?
  notes         String?   @db.Text
  
  raisonSociale     String?
  formeJuridique    String?
  siret             String?
  numeroTVA         String?
  tvaIntracom       String?
  
  adresseRue        String?
  adresseComplement String?
  codePostal        String?
  ville             String?
  pays              String?   @default("France")
  
  delaiPaiement     Int?      @default(30)
  modePaiement      String?
  devise            String?   @default("EUR")
  
  premiereCollabAt  DateTime?
  sourceInitiale    Source?
  prospectePar      String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  contacts      MarqueContact[]
  collaborations Collaboration[]
  negociations  Negociation[]
  prospections  Prospection[]
  demandesGift  DemandeGift[]
  quotes        Quote[]
  
  @@map("marques")
}

model MarqueContact {
  id            String    @id @default(cuid())
  
  marqueId      String
  marque        Marque    @relation(fields: [marqueId], references: [id], onDelete: Cascade)
  
  prenom        String?
  nom           String
  email         String?
  telephone     String?
  poste         String?
  principal     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  quotes        Quote[]
  @@map("marque_contacts")
}

// ============================================
// PROSPECTIONS
// ============================================

model Prospection {
  id            String    @id @default(cuid())
  
  reference     String    @unique
  
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  marqueId      String
  marque        Marque    @relation(fields: [marqueId], references: [id])
  
  statut        StatutProspection @default(NOUVEAU)
  
  notes         String?   @db.Text
  dateContact   DateTime?
  dateRelance   DateTime?
  
  montantEstime Decimal?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([userId])
  @@index([marqueId])
  @@index([statut])
  @@map("prospections")
}

model InboundOpportunity {
  id                String   @id @default(cuid())

  talentEmail       String
  talentName        String
  talentId          String?
  talent            Talent?  @relation(fields: [talentId], references: [id])

  senderEmail       String
  senderName        String?
  senderDomain      String

  subject           String
  bodyExcerpt       String   @db.Text
  gmailMessageId    String   @unique
  threadId          String?
  receivedAt        DateTime

  category          InboundCategory
  confidence        Float
  priority          InboundPriority @default(MEDIUM)

  extractedBrand    String?
  extractedTopic    String?
  extractedBudget   String?
  extractedDeadline String?
  extractedDeliverables String? @db.Text
  briefSummary      String? @db.Text
  draftEmailSubject String?
  draftEmailBody    String? @db.Text

  status            InboundStatus @default(NEW)

  convertedToProspectionId String? @unique
  convertedAt       DateTime?
  convertedById     String?
  convertedBy       User?    @relation("InboundConvertedBy", fields: [convertedById], references: [id])

  archivedAt        DateTime?
  archivedById      String?
  archivedBy        User?    @relation("InboundArchivedBy", fields: [archivedById], references: [id])
  archivedReason    String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([receivedAt])
  @@index([talentId])
  @@index([senderDomain])
  @@index([threadId])
  @@map("inbound_opportunities")
}

// ============================================
// FICHIERS DE PROSPECTION
// ============================================

model FichierProspection {
  id        String   @id @default(cuid())
  titre     String
  mois      Int
  annee     Int

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Dossier optionnel de classement
  dossierId String?
  dossier   DossierProspection? @relation(fields: [dossierId], references: [id])

  contacts  ProspectionContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dossierId])
  @@map("fichiers_prospection")
}

model DossierProspection {
  id        String   @id @default(cuid())
  nom       String

  // Propriétaire du dossier (HEAD/ADMIN peuvent voir tous)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  fichiers  FichierProspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("dossiers_prospection")
}

model ProspectionContact {
  id           String   @id @default(cuid())

  fichierId    String
  fichier      FichierProspection @relation(fields: [fichierId], references: [id], onDelete: Cascade)

  talentId     String?
  talent       Talent?  @relation(fields: [talentId], references: [id])

  nomOpportunite  String
  prenom          String?
  nom             String?
  email           String?
  montantBrut     Decimal? @default(0)
  statut          StatutProspectionContact @default(EN_ATTENTE)
  notes           String?   @db.Text

  // Prochaine action (rappels type NoCRM)
  prochainStatut   StatutAction?
  prochainDate     DateTime?
  actionPrevue     String?   @db.Text
  derniereFait     String?   @db.Text
  actionUpdatedAt  DateTime?

  commentaires    ProspectionCommentaire[]
  historique      ProspectionHistorique[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fichierId])
  @@index([talentId])
  @@index([prochainDate])
  @@map("prospection_contacts")
}

model ProspectionCommentaire {
  id         String   @id @default(cuid())

  contactId  String
  contact    ProspectionContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  auteurId   String
  auteur     User     @relation(fields: [auteurId], references: [id])

  contenu    String
  createdAt  DateTime @default(now())

  @@index([contactId])
  @@map("prospection_commentaires")
}

model ProspectionHistorique {
  id         String   @id @default(cuid())

  contactId  String
  contact    ProspectionContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  auteurId   String
  auteur     User     @relation(fields: [auteurId], references: [id])

  type       String   // "CREATION", "STATUT_CHANGE", "COMMENTAIRE"
  detail     String   // ex: "Statut changé : EN_ATTENTE → EN_NEGOC"
  createdAt  DateTime @default(now())

  @@index([contactId])
  @@map("prospection_historique")
}

// ============================================
// NÉGOCIATIONS
// ============================================

model Negociation {
  id            String    @id @default(cuid())
  
  reference     String    @unique
  
  tmId          String
  tm            User      @relation("TMNegociations", fields: [tmId], references: [id])
  
  talentId      String
  talent        Talent    @relation(fields: [talentId], references: [id])
  
  marqueId      String?
  marque        Marque?   @relation(fields: [marqueId], references: [id])
  nomMarqueSaisi String?  // Nom saisi en négo ; à la validation → find-or-create marque (évite doublons)
  
  contactMarque     String?
  emailContact      String?
  
  source        Source    @default(INBOUND)
  
  brief         String?   @db.Text
  
  livrables     NegoLivrable[]
  
  budgetMarque      Decimal?
  budgetSouhaite    Decimal?
  budgetFinal       Decimal?
  
  dateContact       DateTime  @default(now())
  dateDeadline      DateTime?
  
  statut            StatutNego  @default(BROUILLON)
  
  validePar         String?
  validateur        User?     @relation("ValidateurNegociations", fields: [validePar], references: [id])
  dateValidation    DateTime?
  raisonRefus       String?
  
  collaborationId   String?   @unique
  collaboration     Collaboration? @relation(fields: [collaborationId], references: [id])
  
  commentaires      NegoCommentaire[]
  
  // Tracking des modifications
  modifiedSinceReview  Boolean   @default(false)
  lastModifiedAt       DateTime  @default(now())
  reviewedAt           DateTime?
  dateSubmitted        DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([tmId])
  @@index([talentId])
  @@index([marqueId])
  @@index([statut])
  @@map("negociations")
}

// ============================================
// LIVRABLES NÉGOCIATION
// ============================================

model NegoLivrable {
  id              String   @id @default(cuid())
  
  negociationId   String
  negociation     Negociation @relation(fields: [negociationId], references: [id], onDelete: Cascade)
  
  typeContenu     String   // Texte libre pour plus de flexibilité
  quantite        Int       @default(1)
  prixDemande     Decimal?
  prixSouhaite    Decimal?
  prixFinal       Decimal?
  description     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([negociationId])
  @@map("nego_livrables")
}

// ============================================
// COMMENTAIRES NÉGOCIATION
// ============================================

model NegoCommentaire {
  id              String   @id @default(cuid())
  
  negociationId   String
  negociation     Negociation @relation(fields: [negociationId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  contenu         String   @db.Text
  
  createdAt       DateTime @default(now())
  
  @@index([negociationId])
  @@map("nego_commentaires")
}

// ============================================
// COLLABORATIONS
// ============================================

model Collaboration {
  id            String    @id @default(cuid())
  
  reference     String    @unique
  
  talentId      String
  talent        Talent    @relation(fields: [talentId], references: [id])
  
  marqueId      String
  marque        Marque    @relation(fields: [marqueId], references: [id])
  
  // Account Manager assigné pour le suivi (après deal HEAD_OF_SALES)
  accountManagerId  String?
  accountManager    User?   @relation("AccountManagerCollabs", fields: [accountManagerId], references: [id])
  dateAssignationAM DateTime?
  
  livrables     CollabLivrable[]
  
  source            Source    @default(INBOUND)
  description       String?   @db.Text
  
  montantBrut       Decimal   @default(0)
  commissionPercent Decimal   @default(20)
  commissionEuros   Decimal   @default(0)
  montantNet        Decimal   @default(0)
  
  statut            StatutCollab  @default(NEGO)
  raisonPerdu       String?
  
  lienPublication   String?
  datePublication   DateTime?
  
  factureTalentUrl      String?
  factureTalentRecueAt  DateTime?
  factureValidee        Boolean   @default(false)
  factureValideeAt      DateTime?
  
  marquePayeeAt     DateTime?   // Date à laquelle la marque (client) nous a payés
  paidAt            DateTime?   // Date à laquelle nous avons payé le talent
  
  isLongTerme       Boolean   @default(false)
  
  marqueNotifiee    Boolean   @default(false)

  contratSubmissionId  String?
  contratStatut        String  @default("NON_ENVOYE")
  contratEnvoyeAt      DateTime?
  contratTalentSigneAt DateTime?
  contratSigneAt       DateTime?
  
  contratMarquePdfUrl         String?
  contratMarqueStatut         String   @default("AUCUN")
  contratMarqueEnvoyeJuristeAt DateTime?
  contratMarqueApprouveAt     DateTime?
  contratMarqueSigneAt        DateTime?
  contratMarqueMode           String?
  /** Date du dépôt du PDF / scan officiellement signé (glisser-déposer « version finale signée »). */
  contratMarquePdfOfficielSigneDeposeAt DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  negociation       Negociation?
  
  cycles            CollabCycle[]
  documents         Document[]
  quotes            Quote[]
  comments          CollaborationComment[]
  contratMarqueCommentaires ContratMarqueCommentaire[]
  contratMarqueAnnotations  ContratMarqueAnnotation[]
  contratMarqueVersions     ContratMarqueVersion[]
  contratMarqueVersionActuelle Int @default(0)

  @@index([talentId])
  @@index([marqueId])
  @@index([statut])
  @@index([accountManagerId])
  @@map("collaborations")
}

model ContratMarqueVersion {
  id              String        @id @default(cuid())
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  numero          Int
  pdfUrl          String
  statut          String        @default("EN_ATTENTE_JURISTE")
  uploadedAt      DateTime      @default(now())
  approuveAt      DateTime?
  modifDemandeAt  DateTime?
  annotations            ContratMarqueAnnotation[]
  contratMarqueCommentaires ContratMarqueCommentaire[]

  @@unique([collaborationId, numero])
  @@index([collaborationId])
  @@map("contratMarqueVersion")
}

model ContratMarqueCommentaire {
  id              String   @id @default(cuid())
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  versionId       String?
  version         ContratMarqueVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  auteurId        String
  auteurUser      User     @relation("ContratMarqueCommentaireAuteur", fields: [auteurId], references: [id])
  auteur          String
  auteurRole      String
  contenu         String   @db.Text
  createdAt       DateTime @default(now())

  @@index([collaborationId])
  @@index([auteurId])
  @@index([versionId])
  @@map("contrat_marque_commentaires")
}

model ContratMarqueAnnotation {
  id              String        @id
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  auteurId        String
  auteur          User          @relation(fields: [auteurId], references: [id])
  auteurNom       String
  auteurRole      String
  content         Json
  position        Json
  color           String        @default("#FFE28F")
  type            String        @default("text")
  resolved        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  versionId       String?
  version         ContratMarqueVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([collaborationId])
  @@index([auteurId])
  @@index([versionId])
  @@map("contrat_marque_annotations")
}

// Commentaires sur les collaborations (conversation interne)
model CollaborationComment {
  id              String   @id @default(cuid())
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  content         String   @db.Text
  mentions        CollabCommentMention[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([collaborationId])
  @@map("collaboration_comments")
}

model CollabCommentMention {
  id          String   @id @default(cuid())
  commentId   String
  comment     CollaborationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String
  mentionedBy String
  createdAt   DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
  @@map("collab_comment_mentions")
}

// ============================================
// LIVRABLES COLLABORATION
// ============================================

model CollabLivrable {
  id              String   @id @default(cuid())
  
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  
  typeContenu     String   // Texte libre pour plus de flexibilité
  quantite        Int       @default(1)
  prixUnitaire    Decimal
  description     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collaborationId])
  @@map("collab_livrables")
}

// ============================================
// CYCLES (collabs long terme)
// ============================================

model CollabCycle {
  id            String    @id @default(cuid())
  
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  
  numero        Int
  description   String?
  
  dateDebut     DateTime?
  dateFin       DateTime?
  
  montantBrut       Decimal
  commissionEuros   Decimal
  montantNet        Decimal
  
  statut        StatutCycle   @default(A_VENIR)
  
  lienPublication   String?
  datePublication   DateTime?
  
  factureTalentUrl      String?
  factureTalentRecueAt  DateTime?
  paidAt                DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([collaborationId])
  @@map("collab_cycles")
}

// ============================================
// DOCUMENTS (Devis, BDC, Factures, Avoirs)
// ============================================

model Document {
  id            String    @id @default(cuid())
  
  reference     String    @unique
  
  type          TypeDocument
  statut        StatutDocument  @default(BROUILLON)
  
  collaborationId String?
  collaboration   Collaboration? @relation(fields: [collaborationId], references: [id], onDelete: SetNull)
  
  titre         String?
  
  montantHT     Decimal   @db.Decimal(10, 2)
  tauxTVA       Decimal   @db.Decimal(5, 2) @default(20)
  montantTVA    Decimal   @db.Decimal(10, 2)
  montantTTC    Decimal   @db.Decimal(10, 2)
  
  typeTVA       TypeTVA   @default(FRANCE)
  mentionTVA    String?
  
  lignes        Json?

  // Factures libres (non liées à une collaboration)
  clientNom     String?
  clientEmail   String?
  clientAdresse String?
  clientPays    String?
  
  dateDocument  DateTime  @default(now())
  dateEmission  DateTime  @default(now())
  dateEcheance  DateTime?
  datePaiement  DateTime?
  dateValidation DateTime?
  
  factureRef    String?
  avoirRef      String?
  
  poClient      String?
  
  modePaiement  String?   @default("Virement")
  referencePaiement String?
  
  pdfBase64     String?   @db.Text
  fichierUrl    String?
  
  notes         String?   @db.Text
  
  // Signature électronique DocuSeal
  signatureStatus         String?   // PENDING, SIGNED, DECLINED
  signatureSubmissionId   String?   // ID DocuSeal
  signatureSentAt         DateTime?
  signatureSignedAt       DateTime?
  signatureSignerEmail    String?
  signedDocumentUrl      String?   // URL du PDF signé (DocuSeal)
  signaturesCount        Int       @default(0)  // nb de signatures reçues
  signaturesTotal        Int       @default(2) // nb total de signataires

  createdById   String?
  createdBy     User?     @relation("DocumentCreateur", fields: [createdById], references: [id])
  
  // Historique et commentaires
  events        DocumentEvent[]   @relation("DocumentEvents")
  comments      DocumentComment[] @relation("DocumentComments")
  // Devis lié (si ce document est issu d'un devis)
  linkedQuote   Quote?            @relation("QuoteInvoice")
  
  // Relation transactions Qonto
  transactionsQonto TransactionQonto[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([collaborationId])
  @@index([type, statut])
  @@index([dateEcheance])
  @@index([reference])
  @@index([createdById])
  @@map("documents")
}

// ============================================
// DEVIS (Quotes) & HISTORIQUE DOCUMENTS
// ============================================

model Quote {
  id              String       @id @default(cuid())
  reference       String       @unique    // ex: D-2026-59

  collaborationId String?
  collaboration   Collaboration? @relation(fields: [collaborationId], references: [id])

  marqueId        String
  marque          Marque        @relation(fields: [marqueId], references: [id])

  marqueContactId String?
  marqueContact   MarqueContact? @relation(fields: [marqueContactId], references: [id])

  talentId        String?
  talent          Talent?       @relation(fields: [talentId], references: [id])

  object          String
  issueDate       DateTime      @default(now())
  validUntil      DateTime

  totalHT         Float         @default(0)
  totalTVA        Float         @default(0)
  totalTTC        Float         @default(0)
  currency        String        @default("EUR")
  tvaRate         Float         @default(20.0)

  status          QuoteStatus   @default(DRAFT)
  items           QuoteItem[]

  // Lien vers facture (Document) si converti
  invoiceId       String?       @unique
  invoice         Document?     @relation("QuoteInvoice", fields: [invoiceId], references: [id])
  convertedAt     DateTime?

  pdfUrl          String?
  notes           String?

  // Historique
  events          DocumentEvent[]   @relation("QuoteEvents")
  comments        DocumentComment[] @relation("QuoteComments")

  createdBy       String
  createdByUser   User          @relation(fields: [createdBy], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([marqueId])
  @@index([status])
  @@index([issueDate])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  reference   String?
  designation String
  quantity    Float    @default(1)
  unitPriceHT Float
  discount    Float    @default(0)
  tvaRate     Float    @default(20.0)
  totalHT     Float
  sortOrder   Int      @default(0)

  @@index([quoteId])
}

// Historique des événements sur documents (factures) et devis
model DocumentEvent {
  id          String   @id @default(cuid())

  // Lien vers un document (facture / devis PDF généré) ou un devis Quote
  documentId  String?
  document    Document? @relation("DocumentEvents", fields: [documentId], references: [id], onDelete: Cascade)

  quoteId     String?
  quote       Quote?    @relation("QuoteEvents", fields: [quoteId], references: [id], onDelete: Cascade)

  type        DocumentEventType
  description String?

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  createdAt   DateTime  @default(now())

  @@index([documentId])
  @@index([quoteId])
}

// Commentaires internes sur documents et devis
model DocumentComment {
  id          String   @id @default(cuid())

  documentId  String?
  document    Document? @relation("DocumentComments", fields: [documentId], references: [id], onDelete: Cascade)

  quoteId     String?
  quote       Quote?    @relation("QuoteComments", fields: [quoteId], references: [id], onDelete: Cascade)

  content     String

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  mentions    Mention[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([documentId])
  @@index([quoteId])
}

// Mentions @user dans les commentaires (pour notifications)
model Mention {
  id          String   @id @default(cuid())
  commentId   String
  comment     DocumentComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String   // Utilisateur mentionné
  mentionedBy String   // Qui a mentionné (userId)
  createdAt   DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
  @@map("mentions")
}

// ============================================
// COMPTEURS
// ============================================

model Compteur {
  id            String    @id @default(cuid())
  
  code          String?
  type          String
  annee         Int
  dernierNumero Int       @default(0)
  
  @@unique([type, annee])
  @@index([code])
  @@map("compteurs")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String           @id @default(cuid())
  
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          TypeNotification @default(GENERAL)
  
  titre         String
  message       String
  lien          String?
  lu            Boolean          @default(false)
  luAt          DateTime?
  
  actorId       String?          // Qui a déclenché la notif (ex. qui a mentionné)
  
  marqueId      String?
  talentId      String?
  collabId      String?
  
  createdAt     DateTime         @default(now())
  
  @@index([userId])
  @@index([userId, lu])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

// ============================================
// OBJECTIFS (admin → Head of Influence / Head of)
// ============================================

model Objectif {
  id             String    @id @default(cuid())
  userId         String    // Bénéficiaire (ex. Head of Influence)
  user           User      @relation("ObjectifsRecus", fields: [userId], references: [id], onDelete: Cascade)
  createurId     String    // Admin qui a créé l'objectif
  createur       User      @relation("ObjectifsCrees", fields: [createurId], references: [id], onDelete: Cascade)
  titre          String
  description    String?
  valeurCible    Int?      // Ex. 5 pour "recruter 5 talents"
  valeurActuelle Int?      // Progression (optionnel, peut être mis à jour)
  dateLimite     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@map("objectifs")
}

// ============================================
// PARAMÈTRES AGENCE
// ============================================

model AgenceSettings {
  id            String    @id @default(cuid())
  
  nom               String    @default("Glow Up Agence")
  logo              String?
  
  raisonSociale     String?
  formeJuridique    String?
  capitalSocial     String?
  siret             String?
  numeroTVA         String?
  rcs               String?
  
  adresseRue        String?
  adresseComplement String?
  codePostal        String?
  ville             String?
  pays              String?   @default("France")
  
  telephone         String?
  email             String?
  siteWeb           String?
  
  banque            String?
  iban              String?
  bic               String?
  
  mentionsDevis     String?   @db.Text
  mentionsFacture   String?   @db.Text
  conditionsPaiement String?  @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("agence_settings")
}

model DemandeEntrante {
  id         String   @id @default(cuid())
  from       String
  subject    String
  body       String   @db.Text
  date       DateTime
  status     String   @default("a_traiter")
  emailPret  String?  @db.Text
  sujetPret  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CastingListConfig {
  id            String   @id @default(cuid())
  hubspotListId  String   @unique
  listName      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// TALENTBOOK TRACKING
// ============================================

model TalentbookEvent {
  id        String   @id @default(cuid())
  
  type      String   // "page_view", "talent_click", "pdf_download", "favorite_add"
  
  talentId  String?
  talent    Talent?  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  visitorId String   // ID anonyme du visiteur (stocké en localStorage)
  metadata  Json?    // Données supplémentaires (nombre de talents dans le PDF, etc.)
  
  createdAt DateTime @default(now())

  @@index([type])
  @@index([talentId])
  @@index([createdAt])
  @@map("talentbook_events")
}

// ============================================
// TRANSACTIONS QONTO (RÉCONCILIATION BANCAIRE)
// ============================================

model TransactionQonto {
  id                String    @id @default(cuid())
  qontoId           String    @unique // ID unique de la transaction Qonto
  
  // Informations transaction
  montant           Decimal   @db.Decimal(10, 2)
  devise            String    @default("EUR")
  libelle           String?   // Libellé du virement
  reference         String?   // Référence bancaire
  dateTransaction   DateTime  // Date du virement
  
  // Émetteur
  emetteur          String?   // Nom de l'émetteur
  emetteurIban      String?   // IBAN de l'émetteur
  
  // Statut
  statut            String    @default("PENDING") // PENDING, SETTLED, DECLINED
  
  // Association avec facture
  associe           Boolean   @default(false)
  documentId        String?
  document          Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  
  // Métadonnées brutes Qonto
  metadata          Json?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([documentId])
  @@index([associe])
  @@index([dateTransaction])
  @@index([statut])
  @@map("transactions_qonto")
}

// ============================================
// DEMANDES DE GIFTS
// ============================================

model DemandeGift {
  id                String        @id @default(cuid())
  reference         String        @unique // Format : GIFT-2026-0001
  
  // Relations
  talentId          String
  talent            Talent        @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  tmId              String
  tm                User          @relation("TMDemandeGift", fields: [tmId], references: [id])
  
  accountManagerId  String?
  accountManager    User?         @relation("AMDemandeGift", fields: [accountManagerId], references: [id])
  
  marqueId          String?
  marque            Marque?       @relation(fields: [marqueId], references: [id])
  
  // Détails de la demande
  statut            StatutGift    @default(BROUILLON)
  priorite          String        @default("NORMALE") // BASSE, NORMALE, HAUTE, URGENTE
  
  typeGift          String        // PRODUIT, EXPERIENCE, SERVICE, AUTRE
  description       String        @db.Text
  justification     String?       @db.Text // Pourquoi ce gift est important
  valeurEstimee     Decimal?      @db.Decimal(10, 2)
  
  // Informations supplémentaires
  datesouhaitee     DateTime?     // Date souhaitée de réception
  adresseLivraison  String?       @db.Text
  notesInternes     String?       @db.Text

  // Informations hébergement (pour typeGift = "HOTEL")
  destination        String?       // Ville / pays
  dateArrivee        DateTime?     // Check-in
  dateDepart         DateTime?     // Check-out
  nombrePersonnes    Int?          // Nombre de personnes
  typeHebergement    String?       // HOTEL, APPARTEMENT, VILLA, AUTRE
  categorie          String?       // 3*, 4*, 5*, LUXE
  demandesSpeciales  String?       @db.Text  // Suite, vue mer, petit-déj inclus, etc.

  // Contrepartie (renseignée par l'AM quand la marque accepte)
  contrepartieType   String?       // AUCUNE, STORY, POST_FEED, REEL_TIKTOK, MENTION_STORY, CHOIX_TALENT
  contrepartieDelai  Int?          // Délai en jours après réception pour poster
  contrepartieNotes  String?       @db.Text  // Précisions libres
  contreparties      Json?         @default("[]")

  // Infos retour marque (pour PRODUIT / GIFT classique)
  contactMarqueNom     String?     // Nom du contact chez la marque
  contactMarqueEmail   String?     // Email du contact
  dateExpeditionPrevue DateTime?   // Date d'expédition estimée

  // Infos retour hôtel (pour HOTEL)
  numeroReservation  String?       // Numéro de confirmation de résa
  nomReservation     String?       // Nom sous lequel la résa est faite
  adresseHotel       String?       @db.Text
  contactSurPlace    String?       // Qui demander à l'accueil
  horaireCheckIn     String?       // Ex: "À partir de 15h"
  horaireCheckOut    String?       // Ex: "Avant 12h"
  
  // Suivi
  datePriseEnCharge DateTime?     // Quand l'AM a pris en charge
  dateContactMarque DateTime?     // Quand l'AM a contacté la marque
  dateReponseMarque DateTime?     // Quand la marque a répondu
  dateEnvoi         DateTime?     // Date d'envoi du gift
  dateReception     DateTime?     // Date de réception par le talent
  
  numeroSuivi       String?       // Numéro de suivi du colis
  
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  // Relations
  commentaires      CommentaireGift[]
  
  @@index([talentId])
  @@index([tmId])
  @@index([accountManagerId])
  @@index([marqueId])
  @@index([statut])
  @@index([priorite])
  @@index([createdAt])
  @@map("demandes_gift")
}

model CommentaireGift {
  id              String      @id @default(cuid())
  
  demandeGiftId   String
  demandeGift     DemandeGift @relation(fields: [demandeGiftId], references: [id], onDelete: Cascade)
  
  auteurId        String
  auteur          User        @relation(fields: [auteurId], references: [id])
  
  contenu         String      @db.Text
  interne         Boolean     @default(false) // Si true, visible uniquement par TM et AM
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([demandeGiftId])
  @@index([auteurId])
  @@index([createdAt])
  @@map("commentaires_gift")
}

// ============================================
// SYSTÈME PRESS KIT AUTOMATISÉ
// ============================================

model Brand {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  domain          String?
  niche           String
  hubspotId       String?          @unique
  description     String           @db.Text // OBLIGATOIRE : décrit précisément ce que vend la marque
  logo            String?          // URL logo récupéré via Brandfetch
  primaryColor    String?          // Couleur primaire de la marque (#hex)
  secondaryColor  String?          // Couleur secondaire de la marque (#hex)
  category        String?          // Catégorie : MODE, BEAUTÉ, SPORT, FOOD, TECH, LIFESTYLE, SANTÉ, FINANCE, AUTRE
  presskitTalents PressKitTalent[]
  pageViews       PageView[]
  batches         BatchBrand[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([slug])
  @@index([hubspotId])
  @@index([niche])
  @@map("brands")
}

model PressKitTalent {
  id          String   @id @default(cuid())
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  talent      Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  talentId    String
  pitch       String   @db.Text // Phrase de vente percutante
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([brandId, talentId])
  @@index([brandId])
  @@index([talentId])
  @@map("presskit_talents")
}

model CaseStudy {
  id          String   @id @default(cuid())
  title       String
  brandName   String
  niche       String
  description String   @db.Text
  impressions String?
  engagement  String?
  extraMetric String?
  extraLabel  String?
  imageUrl    String?  // Photo de la campagne
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([niche])
  @@map("case_studies")
}

model PageView {
  id                 String   @id @default(cuid())
  brand              Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId            String
  hubspotContactId   String?
  refParam           String?  // ?ref= du lien tracké (ex: marie-sephora)
  sessionId          String   // ID unique de session
  durationSeconds    Int      @default(0)
  scrollDepthPercent Int      @default(0)
  talentsViewed      String[] // IDs des talents qui ont été vus
  talentDurations    Json?    // Durées par talent: { "talentId": durationSeconds }
  visitNumber        Int      @default(1)
  ctaClicked         Boolean  @default(false)
  talentbookClicked  Boolean  @default(false) // Clic sur le lien "Voir le Talent Book complet"
  userAgent          String?
  ipAddress          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@index([brandId])
  @@index([sessionId])
  @@index([hubspotContactId])
  @@index([createdAt])
  @@map("page_views")
}

model Batch {
  id          String       @id @default(cuid())
  name        String
  status      String       @default("processing") // processing, completed, failed
  totalBrands Int
  completed   Int          @default(0)
  failed      Int          @default(0)
  brands      BatchBrand[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([status])
  @@index([createdAt])
  @@map("batches")
}

model BatchBrand {
  id                String   @id @default(cuid())
  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId           String
  brand             Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId           String
  status            String   @default("pending") // pending, generating, completed, failed
  error             String?  @db.Text
  talentIds         String[] @default([]) // Talents spécifiques pour cette marque (override du défaut si fourni)
  hubspotContactIds String[] @default([]) // IDs des contacts HubSpot associés (plusieurs contacts par marque)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([batchId, brandId])
  @@index([batchId])
  @@index([brandId])
  @@index([status])
  @@map("batch_brands")
}

// ============================================
// PARTNER TALENT BOOK
// ============================================

model Partner {
  id          String   @id @default(cuid())
  name        String                          // "WOO", "Influence4You", etc.
  slug        String   @unique                // lien unique : /partners/[slug]
  logo        String?                         // URL logo agence (Cloudinary)
  contactName String?                         // Nom du contact principal
  contactEmail String?                        // Email contact
  isActive    Boolean  @default(true)         // Actif ou désactivé
  showAllTalents Boolean @default(true)       // true = affiche TOUS les talents actifs automatiquement
  
  // Personnalisation
  description String?                         // Description libre
  message     String?                         // Message d'accueil personnalisé
  
  // Talents sélectionnés
  talents     PartnerTalent[]
  
  // Analytics
  views       PartnerView[]
  
  // Tarifs négociés
  tarifOverrides PartnerTarifOverride[]
  
  // Projets affichés sur la page partenaire (vide = tous les projets actifs)
  projects     PartnerProject[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?                         // ID de l'admin qui a créé
  
  @@index([slug])
  @@index([isActive])
  @@map("partners")
}

model PartnerTalent {
  id        String   @id @default(cuid())
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  talentId  String
  talent    Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  order     Int      @default(0)              // Ordre d'affichage
  createdAt DateTime @default(now())
  
  @@unique([partnerId, talentId])
  @@index([partnerId])
  @@index([talentId])
  @@map("partner_talents")
}

model PartnerView {
  id              String   @id @default(cuid())
  partnerId       String
  partner         Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  visitorId       String                      // Cookie ou fingerprint
  
  // Tracking
  talentClicked   String?                     // ID du talent cliqué (si modal ouverte)
  talentName      String?                     // Nom du talent (pour stats rapides)
  action          String   @default("view")   // "view", "talent_click", "cta_click", "filter"
  duration        Int?                        // Durée en secondes
  metadata        Json?                       // Données supplémentaires (filtres utilisés, etc.)
  
  // Source
  referrer        String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
  
  @@index([partnerId])
  @@index([partnerId, createdAt])
  @@index([action])
  @@map("partner_views")
}

model PartnerTarifOverride {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  talentId    String
  talent      Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  // Tarifs négociés — null = utiliser le tarif par défaut du talent
  // Mapping avec TalentTarifs : tarifStory -> storyIg, tarifPost -> postIg, etc.
  tarifStory          Decimal?  // Story Instagram
  tarifPost           Decimal?  // Post Instagram
  tarifReel           Decimal?  // Reel Instagram
  tarifStoryConcours  Decimal?  // Story Concours
  tarifPostConcours   Decimal?  // Post Concours
  tarifTiktokVideo    Decimal?  // Vidéo TikTok
  tarifYoutubeVideo   Decimal?  // Vidéo YouTube
  tarifYoutubeShort   Decimal?  // YouTube Short
  tarifPostCommun     Decimal?  // Post Commun (UGC)
  tarifEvent          Decimal?  // Event / Apparition
  tarifShooting       Decimal?  // Shooting photo
  tarifAmbassadeur    Decimal?  // Pack Ambassadeur
  
  note        String?  @db.Text  // Note interne ("Tarif négocié contrat annuel 2025")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([partnerId, talentId])
  @@index([partnerId])
  @@index([talentId])
  @@map("partner_tarif_overrides")
}

model DelegationTM {
  id           String   @id @default(cuid())
  talentId     String
  tmOrigineId  String
  tmRelaiId    String
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  talent    Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
  tmOrigine User   @relation("DelegationsEmises", fields: [tmOrigineId], references: [id], onDelete: Cascade)
  tmRelai   User   @relation("DelegationsRecues", fields: [tmRelaiId], references: [id], onDelete: Cascade)

  activites DelegationActivite[]

  @@unique([talentId, tmRelaiId])
}

// ============================================
// AGENCY PROJECTS (PORTFOLIO GLOW UP)
// ============================================

model AgencyProject {
  id          String   @id @default(cuid())
  title       String                          // "LONDON NICE"
  slug        String   @unique
  description String?  @db.Text               // Description du projet
  coverImage  String?                         // Photo principale (Cloudinary)
  images      Json?                           // ["url1", "url2", ...] galerie photos
  links       Json?                           // [{ label, url }, ...] liens externes (articles, réseaux...)
  videoUrl    String?                         // Lien vidéo (YouTube, Vimeo)
  
  // Infos projet
  category    String?                         // "Event", "Production", "Shooting", "Concept"
  date        DateTime?                       // Date du projet
  location    String?                         // "Londres → Nice"
  
  // Talents impliqués
  talents     AgencyProjectTalent[]
  
  // Partenaires qui affichent ce projet (via PartnerProject)
  partners    PartnerProject[]
  
  // Visibilité
  isActive    Boolean  @default(true)
  order       Int      @default(0)            // Ordre d'affichage
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@map("agency_projects")
}

model PartnerProject {
  id        String         @id @default(cuid())
  partnerId String
  partner   Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  projectId String
  project   AgencyProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order     Int            @default(0)       // Ordre d'affichage pour ce partenaire
  
  createdAt DateTime @default(now())
  
  @@unique([partnerId, projectId])
  @@index([partnerId])
  @@index([projectId])
  @@map("partner_projects")
}

model AgencyProjectTalent {
  id        String         @id @default(cuid())
  projectId String
  project   AgencyProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  talentId  String
  talent    Talent         @relation(fields: [talentId], references: [id], onDelete: Cascade)
  role      String?                           // "Host", "Participant", etc.
  
  @@unique([projectId, talentId])
  @@index([projectId])
  @@index([talentId])
  @@map("agency_project_talents")
}

model DelegationActivite {
  id             String   @id @default(cuid())
  delegationId   String
  talentId       String
  auteurId       String
  type           String
  entiteType     String
  entiteId       String
  entiteRef      String?
  detail         String?
  ancienneValeur String?
  nouvelleValeur String?
  createdAt      DateTime @default(now())

  delegation DelegationTM @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  talent     Talent       @relation(fields: [talentId], references: [id], onDelete: Cascade)
  auteur     User         @relation(fields: [auteurId], references: [id], onDelete: Cascade)

  @@index([delegationId])
  @@index([talentId])
  @@index([auteurId])
  @@map("delegation_activites")
}

model ProjetEvenement {
  id        String   @id @default(cuid())
  nom       String
  slug      String   @unique
  dateDebut DateTime
  dateFin   DateTime
  lieu      String?
  statut    String   @default("ACTIF")
  createdAt DateTime @default(now())

  opportunites OpportuniteMarque[]
  participantsVilla ParticipantVilla[]
}

model OpportuniteMarque {
  id             String          @id @default(cuid())
  projetId       String
  projet         ProjetEvenement @relation(fields: [projetId], references: [id])

  nomMarque      String
  secteur        String?
  angleNote      String?
  budgetEstime   Int?
  typeActivation String?
  dateActivation DateTime?
  montantFinal   Int?
  statutLivraison String @default("A_FAIRE")

  // [{firstName, lastName, email, role}] — jamais exposé au STRATEGY_PLANNER
  contacts       Json    @default("[]")
  contactQualifie Boolean @default(false)

  // A_QUALIFIER | IDENTIFIEE | CONTACTEE | EN_NEGO | SIGNEE | PERDUE
  statut         String  @default("A_QUALIFIER")
  talents        Json    @default("[]")

  ownerId        String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projetId])
}

model ParticipantVilla {
  id          String         @id @default(cuid())
  projetId    String
  projet      ProjetEvenement @relation(fields: [projetId], references: [id], onDelete: Cascade)
  talentId    String
  talent      Talent         @relation(fields: [talentId], references: [id], onDelete: Cascade)
  dateArrivee DateTime?
  dateDepart  DateTime?
  // PRESSENTI | CONFIRME | DESISTE
  statut      String         @default("PRESSENTI")
  notes       String?
  createdAt   DateTime       @default(now())

  @@unique([projetId, talentId])
  @@index([projetId])
  @@index([talentId])
}

model DinnerCampaign {
  id          String              @id @default(cuid())
  projetSlug  String              @default("villa-cannes")
  name        String
  clientName  String
  clientAccessToken String        @unique
  logoUrl     String?
  eventPhotos Json?
  reportingSummary String?        @db.Text
  reportingKpis Json?
  city        String?
  eventDate   DateTime?
  budgetMin   Decimal?            @db.Decimal(10, 2)
  budgetMax   Decimal?            @db.Decimal(10, 2)
  status      DinnerCampaignStatus @default(DRAFT)
  createdById String
  createdBy   User                @relation("DinnerCampaignCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  candidates DinnerCreatorCandidate[]
  events     DinnerCandidateEvent[]

  @@index([projetSlug, createdAt])
  @@index([status])
  @@map("dinner_campaigns")
}

model DinnerCreatorCandidate {
  id              String               @id @default(cuid())
  campaignId      String
  campaign        DinnerCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  talentId        String?
  talent          Talent?              @relation(fields: [talentId], references: [id], onDelete: SetNull)
  manualHandle    String?
  creatorEmail    String?
  instagramUrl    String?
  manualPlatform  String?
  fullName        String
  followers       Int?
  engagementRate  Decimal?             @db.Decimal(5, 2)
  estimatedCost   Decimal?             @db.Decimal(10, 2)
  notePlanner     String?
  noteClient      String?
  source          DinnerCandidateSource @default(PLANNER)
  status          DinnerCandidateStatus @default(PROPOSED)
  rejectionReason String?
  position        Int                  @default(0)
  createdById     String
  createdBy       User                 @relation("DinnerCandidateCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User                 @relation("DinnerCandidateUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  events   DinnerCandidateEvent[]
  comments DinnerCandidateComment[]

  @@index([campaignId, status, position])
  @@index([campaignId, talentId])
  @@map("dinner_creator_candidates")
}

model ContactMission {
  id                  String                @id @default(cuid())
  campaignId          String?
  campaign            TalentProspectingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  talentId            String?
  talent              Talent?               @relation(fields: [talentId], references: [id], onDelete: SetNull)
  creatorName         String
  targetBrand         String
  targetBrandKey      String
  strategyReason      String                @db.Text
  recommendedAngle    String?               @db.Text
  objective           String?
  dos                 String?               @db.Text
  donts               String?               @db.Text
  priority            ContactMissionPriority @default(MEDIUM)
  status              ContactMissionStatus   @default(READY_FOR_CASTING)
  stage               ContactMissionStage    @default(TO_DRAFT)
  draftEmailSubject   String?                @db.Text
  draftEmailBody      String?                @db.Text
  clientLanguage      String?
  clientContacts      Json?
  deadlineAt          DateTime?
  createdById         String
  createdBy           User                  @relation("ContactMissionCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([campaignId, stage, createdAt])
  @@index([talentId])
  @@index([targetBrandKey, status, createdAt])
  @@map("contact_missions")
}

model TalentProspectingCampaign {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  talentId      String
  talent        Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User     @relation("TalentProspectingCampaignCreatedBy", fields: [createdById], references: [id])
  isActive      Boolean  @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contactMissions ContactMission[]

  @@index([createdById, isActive, createdAt])
  @@index([talentId, isActive, createdAt])
  @@map("talent_prospecting_campaigns")
}

model DinnerCandidateEvent {
  id          String            @id @default(cuid())
  candidateId String
  candidate   DinnerCreatorCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    DinnerCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        DinnerEventType
  fromStatus  DinnerCandidateStatus?
  toStatus    DinnerCandidateStatus?
  payload     Json?
  actorId     String
  actor       User              @relation(fields: [actorId], references: [id])
  createdAt   DateTime          @default(now())

  @@index([campaignId, createdAt])
  @@index([candidateId, createdAt])
  @@map("dinner_candidate_events")
}

model DinnerCandidateComment {
  id          String            @id @default(cuid())
  candidateId String
  candidate   DinnerCreatorCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String
  author      User              @relation(fields: [authorId], references: [id])
  content     String            @db.Text
  createdAt   DateTime          @default(now())

  @@index([candidateId, createdAt])
  @@map("dinner_candidate_comments")
}

// =============================================
// MODULE CANNES 2026
// =============================================

enum CannesEventType {
  SOIREE
  DINER
  BRUNCH
  COCKTAIL
  CONFERENCE
  PROJECTION
  SHOOTING
  AUTRE
}

enum CannesContactCategory {
  MARQUE
  AGENCE
  PRESSE
  PRODUCTION
  HOTEL
  TRANSPORT
  TALENT_EXT
  AUTRE
}

model CannesEvent {
  id             String          @id @default(cuid())
  date           DateTime
  startTime      String
  endTime        String?
  title          String
  type           CannesEventType @default(SOIREE)
  location       String
  address        String?
  organizer      String?
  contactInfo    String?
  dressCode      String?
  invitationLink String?
  description    String?         @db.Text
  notes          String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  attendees      CannesEventAttendee[]

  @@index([date])
}

model CannesContact {
  id            String                @id @default(cuid())
  firstName     String
  lastName      String
  company       String?
  role          String?
  phone         String?
  email         String?
  instagram     String?
  hotel         String?
  arrivalDate   DateTime?
  departureDate DateTime?
  category      CannesContactCategory @default(AUTRE)
  notes         String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([category])
}

model CannesPresence {
  id              String   @id @default(cuid())
  userId          String?
  talentId        String?
  arrivalDate     DateTime
  departureDate   DateTime
  hotel           String?
  hotelAddress    String?
  flightArrival   String?
  flightDeparture String?
  roomNumber      String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation("UserCannesPresences", fields: [userId], references: [id], onDelete: Cascade)
  talent          Talent?  @relation("TalentCannesPresences", fields: [talentId], references: [id], onDelete: Cascade)
  attendances     CannesEventAttendee[]

  @@index([userId])
  @@index([talentId])
}

model CannesEventAttendee {
  id         String         @id @default(cuid())
  eventId    String
  presenceId String
  createdAt  DateTime       @default(now())
  event      CannesEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  presence   CannesPresence @relation(fields: [presenceId], references: [id], onDelete: Cascade)

  @@unique([eventId, presenceId])
  @@index([eventId])
  @@index([presenceId])
}
