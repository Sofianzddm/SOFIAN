NEXT_PUBLIC_CANNES_COIFFEUR_STYLIST_PHONE="06 63 88 82 47"
# Réception des copies confirmation réservation coiffeur (optionnel)
CANNES_COIFFEUR_NOTIFY_EMAIL=""
# Expéditeur Resend pour emails coiffeur (confirmations / annulations ; défaut code : contact@glowupagence.fr)
CANNES_COIFFEUR_FROM_EMAIL="contact@glowupagence.fr"
# Secret HMAC pour signer les tokens d'annulation (32+ chars aléatoires)
CANNES_COIFFEUR_TOKEN_SECRET=""
# Whitelist IPs pour bypass rate-limit coiffeur (CSV, optionnel)
