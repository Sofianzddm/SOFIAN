# Database
DATABASE_URL="postgresql://..."

# NextAuth — en prod, définir au moins l’une des deux (sinon secours auto : projet Vercel / DATABASE_URL)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="..."
# AUTH_SECRET="..."

# Base URL (pour génération des liens press kit)
NEXT_PUBLIC_BASE_URL="https://app.glowupagence.fr"

# Brandfetch API (logo + couleurs des marques)
# Créer un compte gratuit sur https://brandfetch.com
BRANDFETCH_API_KEY=""

# Anthropic Claude API (génération pitchs IA)
# Créer un compte sur https://console.anthropic.com
ANTHROPIC_API_KEY=""

# HubSpot API (CRM + webhook)
# Créer une Private App dans HubSpot Settings
HUBSPOT_API_KEY=""

# Amazon S3 (stockage des fichiers : photos talents, logos, factures, PDF...)
# 1. Créer un bucket S3 (ex. eu-west-3 / Paris)
# 2. Créer un utilisateur IAM avec accès s3:PutObject / s3:DeleteObject / s3:GetObject sur ce bucket
# 3. Autoriser la lecture publique des objets (bucket policy) OU mettre une distribution CloudFront
# 4. Configurer le CORS du bucket pour autoriser PUT depuis l'app (voir README migration)
AWS_REGION="eu-west-3"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optionnel : domaine public CloudFront/custom (sinon URL S3 par défaut). Sans slash final.
AWS_S3_PUBLIC_URL=""
# CORS du bucket (console S3 > Permissions > CORS) — requis pour les uploads directs navigateur :
# [
#   {
#     "AllowedHeaders": ["*"],
#     "AllowedMethods": ["GET", "PUT", "HEAD"],
#     "AllowedOrigins": ["http://localhost:3000", "https://app.glowupagence.fr"],
#     "ExposeHeaders": ["ETag"]
#   }
# ]
# Lecture publique : bucket policy ou distribution CloudFront devant le bucket.

# Cloudinary — conservé uniquement pour migrer les anciens fichiers (scripts/migrate-cloudinary-to-s3.ts)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Apify (import automatique des photos Instagram dans le Kit Media)
# Créer un compte gratuit sur https://apify.com (5€ de crédit offerts)
# Token dispo dans Settings > Integrations > Personal API tokens
APIFY_TOKEN=""

# Qonto API (réconciliation bancaire - optionnel)
# Header Authorization = login:secret (sans "Bearer", sans Base64)
# Option A — une seule variable :
QONTO_API_KEY="votre-login-qonto:votre-secret-key"
# Option B — login + secret séparés (le login = "Sign-in" affiché dans Qonto > API key) :
# QONTO_ORGANIZATION_SLUG="votre-login-qonto"
# QONTO_SECRET_KEY="votre-secret-key"
# Forcer un compte bancaire précis (sinon = compte principal détecté auto)
# QONTO_BANK_ACCOUNT_ID=""
# Secret HMAC du webhook Qonto (32+ caractères — même valeur que lors de POST /v2/webhook_subscriptions)
# QONTO_WEBHOOK_SECRET=""
# URL callback production : https://app.glowupagence.fr/api/webhooks/qonto
# Types à souscrire : ["v1/transactions"]
# Voir scripts/register-qonto-webhook.sh pour créer l’abonnement via curl

# Cron Vercel — secret partagé pour /api/cron/* (synchro Qonto, relances, etc.)
# Vercel l'envoie automatiquement dans le header Authorization quand la var est définie.
CRON_SECRET=""

# DocuSeal (signature électronique sur devis)
# Créer une clé API sur https://console.docuseal.com/api
DOCUSEAL_API_KEY=""
# Email du compte DocuSeal (authentification du builder, pas les signataires)
DOCUSEAL_ACCOUNT_EMAIL="s.zeddam@glowupagence.fr"
# Contrat talent (template DocuSeal + signataire agence)
DOCUSEAL_CONTRAT_TALENT_TEMPLATE_ID=""
AGENCE_SIGNATURE_EMAIL=""
JURISTE_EMAIL=""
# URL publique DocuSeal (lien « Voir le contrat signé »)
NEXT_PUBLIC_DOCUSEAL_URL="https://docuseal.com"

# Signataire agence (modale signature DocuSeal — signataire 2 fixe)
NEXT_PUBLIC_AGENCE_EMAIL="contrat@glowupagence.fr"
NEXT_PUBLIC_AGENCE_NOM="Sofian Zeddam"

# Resend (email branded Glow Up pour envoi devis en signature)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="contrat@glowupagence.fr"

# Inbound opportunities API (Google Apps Script -> Platform)
INBOUND_API_SECRET=""

# Cannes 2026 — lieu figurant dans les emails de confirmation réservation coiffeur
