# Database
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="..."

# Base URL (pour génération des liens press kit)
NEXT_PUBLIC_BASE_URL="https://app.glowupagence.fr"

# Brandfetch API (logo + couleurs des marques)
# Créer un compte gratuit sur https://brandfetch.com
BRANDFETCH_API_KEY=""

# Anthropic Claude API (génération pitchs IA)
# Créer un compte sur https://console.anthropic.com
ANTHROPIC_API_KEY=""

# HubSpot API (CRM + webhook)
# Créer une Private App dans HubSpot Settings
HUBSPOT_API_KEY=""

# Cloudinary (upload images - optionnel si migration Vercel Blob faite)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Qonto API (réconciliation bancaire - optionnel)
QONTO_API_KEY=""
QONTO_ORGANIZATION_SLUG=""

# DocuSeal (signature électronique sur devis)
# Créer une clé API sur https://console.docuseal.com/api
DOCUSEAL_API_KEY=""
# Email du compte DocuSeal (authentification du builder, pas les signataires)
DOCUSEAL_ACCOUNT_EMAIL="s.zeddam@glowupagence.fr"
# Contrat talent (template DocuSeal + signataire agence)
DOCUSEAL_CONTRAT_TALENT_TEMPLATE_ID=""
AGENCE_SIGNATURE_EMAIL=""
JURISTE_EMAIL=""
# URL publique DocuSeal (lien « Voir le contrat signé »)
NEXT_PUBLIC_DOCUSEAL_URL="https://docuseal.com"

# Signataire agence (modale signature DocuSeal — signataire 2 fixe)
NEXT_PUBLIC_AGENCE_EMAIL="contrat@glowupagence.fr"
NEXT_PUBLIC_AGENCE_NOM="Sofian Zeddam"

# Resend (email branded Glow Up pour envoi devis en signature)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="contrat@glowupagence.fr"

# Inbound opportunities API (Google Apps Script -> Platform)
INBOUND_API_SECRET=""

# Cannes 2026 — lieu figurant dans les emails de confirmation réservation coiffeur
CANNES_COIFFEUR_LOCATION=""
# Prénom & téléphone affichés page publique + mails (optionnel ; défauts Sofiane / 06 63 88 82 47 dans le code)
NEXT_PUBLIC_CANNES_COIFFEUR_STYLIST_FIRST_NAME=Sofiane
NEXT_PUBLIC_CANNES_COIFFEUR_STYLIST_PHONE="06 63 88 82 47"
# Réception des copies confirmation réservation coiffeur (optionnel)
CANNES_COIFFEUR_NOTIFY_EMAIL=""
# Expéditeur Resend pour emails coiffeur (confirmations / annulations ; défaut code : contact@glowupagence.fr)
CANNES_COIFFEUR_FROM_EMAIL="contact@glowupagence.fr"
# Secret HMAC pour signer les tokens d'annulation (32+ chars aléatoires)
CANNES_COIFFEUR_TOKEN_SECRET=""
# Whitelist IPs pour bypass rate-limit coiffeur (CSV, optionnel)
CANNES_COIFFEUR_RATE_LIMIT_BYPASS_IPS=""
# URL publique de l'app (liens email: gestion/annulation)
NEXT_PUBLIC_APP_URL="https://app.glowupagence.fr"
# Page publique /r/cannes-coiffeur — encart portrait (URL absolue, ex. Cloudinary) + handle Instagram
# Sans photo : pictogramme ciseaux par défaut ; handle par défaut @regardesacoiffure si variable vide
NEXT_PUBLIC_CANNES_COIFFEUR_PROFILE_IMAGE_URL=""
NEXT_PUBLIC_CANNES_COIFFEUR_SOCIAL_HANDLE="regardesacoiffure"
